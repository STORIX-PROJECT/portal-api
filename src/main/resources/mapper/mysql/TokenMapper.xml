<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shop.storix.portalapi.mapper.auth.TokenMapper">
    <insert id="save" parameterType="com.shop.storix.portalapi.model.dto.auth.domain.AuthDto$Token">
        INSERT INTO OMS.LOGIN_REFRESH_TOKEN (
            USER_LOGIN_NO,
            REFRESH_TOKEN
        )
        VALUES (
            #{userLoginNo},
            #{refreshToken}
        )
    </insert>

    <select id="findById" resultType="com.shop.storix.portalapi.model.dto.auth.domain.AuthDto$Token">
        SELECT
            USER_LOGIN_NO,
            REFRESH_TOKEN
        FROM OMS.LOGIN_REFRESH_TOKEN
        WHERE
            USER_LOGIN_NO = #{userLoginNo}
        ORDER BY CREATED_AT DESC
        LIMIT 1
    </select>

    <delete id="delete">
        DELETE
        FROM LOGIN_REFRESH_TOKEN
        WHERE
            REFRESH_TOKEN = #{refreshToken}
    </delete>

</mapper>